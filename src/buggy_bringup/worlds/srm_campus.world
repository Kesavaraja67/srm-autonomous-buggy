<?xml version="1.0"?>
<sdf version="1.6">
  <world name="srm_campus">

    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <model name="main_gate">
      <static>true</static>
      <pose>-40 0 1 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>4 2 2</size></box></geometry>
          <material><ambient>0.8 0.6 0.2 1</ambient></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>4 2 2</size></box></geometry>
        </collision>
      </link>
    </model>

    <model name="library">
      <static>true</static>
      <pose>40 0 2 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>8 6 4</size></box></geometry>
          <material><ambient>0.2 0.4 0.8 1</ambient></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>8 6 4</size></box></geometry>
        </collision>
      </link>
    </model>

    <model name="admin_block">
      <static>true</static>
      <pose>0 30 2.5 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>10 8 5</size></box></geometry>
          <material><ambient>0.8 0.2 0.2 1</ambient></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>10 8 5</size></box></geometry>
        </collision>
      </link>
    </model>

    <model name="canteen">
      <static>true</static>
      <pose>0 -30 1.5 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>6 6 3</size></box></geometry>
          <material><ambient>0.2 0.8 0.2 1</ambient></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>6 6 3</size></box></geometry>
        </collision>
      </link>
    </model>

    <model name="parking">
      <static>true</static>
      <pose>-40 30 0.1 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>12 10 0.2</size></box></geometry>
          <material><ambient>0.4 0.4 0.4 1</ambient></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>12 10 0.2</size></box></geometry>
        </collision>
      </link>
    </model>

    <model name="hub">
      <static>true</static>
      <pose>0 0 0.05 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><cylinder><radius>5</radius><length>0.1</length></cylinder></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient></material>
        </visual>
        <collision name="collision">
          <geometry><cylinder><radius>5</radius><length>0.1</length></cylinder></geometry>
        </collision>
      </link>
    </model>

    <model name="test_obstacle">
      <static>true</static>
      <pose>20 0 0.5 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>1 1 1</size></box></geometry>
          <material><ambient>1 0 0 1</ambient></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>1 1 1</size></box></geometry>
        </collision>
      </link>
    </model>

  </world>
</sdf>
